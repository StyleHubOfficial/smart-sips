rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - name: string (optional)
    //   - role: string (required, enum: ['teacher', 'admin', 'developer'])
    //   - badge: string (optional)
    //   - profileIcon: string (optional)
    //
    // Collection: messages
    // Document ID: messageId
    // Fields:
    //   - senderId: string (required)
    //   - receiverId: string (required)
    //   - text: string (required, max 1000 chars)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: ['sent', 'delivered', 'read'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
       return request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "santrak116@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDeveloper() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer' ||
          (request.auth.token.email == "santrak116@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isDeveloper());
      allow create: if isAuthenticated() && isOwner(userId) && hasRequiredFields(['uid', 'email', 'role']);
      allow update: if isAuthenticated() && isOwner(userId) && request.resource.data.role == resource.data.role;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isDeveloper() ||
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        (resource.data.keys().hasAny(['participants']) && request.auth.uid in resource.data.participants)
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.senderId
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        isDeveloper() ||
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        (resource.data.keys().hasAny(['participants']) && request.auth.uid in resource.data.participants)
      );
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isDeveloper();
    }
  }
}
